# Core runtime
APP_ENV=dev
APP_NAME=multi-tenant-ai-concierge
APP_HOST=0.0.0.0
APP_PORT=8000

# Database - Hanan owns the PostgreSQL + RLS setup
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/concierge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=concierge

# Cache / session memory - Hanan owns the tenant-safe session boundaries
REDIS_URL=redis://localhost:6379/0

# Object storage - Hanan owns blob lifecycle and erasure paths
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=http://localhost:9000

# Secrets - Hanan owns Vault integration and service tokens
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=change-me
SERVICE_TOKEN=dev-service-token

# Widget auth - Ali Faddel owns the embed flow, token exchange, and origin checks
WIDGET_ISSUER=concierge-widget
WIDGET_TOKEN_TTL_SECONDS=300
WIDGET_SHARED_SECRET=dev-widget-secret
WIDGET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8000
TENANT_ID_HEADER=X-Tenant-Id
REQUEST_ID_HEADER=X-Request-Id
ACTOR_ROLE_HEADER=X-Actor-Role
ACTOR_SUBJECT_HEADER=X-Actor-Subject

# Model / AI - Mohammad and Rayan coordinate these runtime settings
OPENAI_API_KEY=replace-me
GEMINI_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-large
CHAT_MODEL=gpt-4.1-mini
CLASSIFIER_MODEL=classifier.onnx
CLASSIFIER_URL=http://localhost:8010/v1

# Observability - Rayan owns traces and eval visibility
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=concierge-api
