# Core runtime
APP_ENV=dev
APP_NAME=multi-tenant-ai-concierge
APP_HOST=0.0.0.0
APP_PORT=8000

# Database - Mohammad owns the PostgreSQL + RLS setup
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/concierge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=concierge

# Cache / session memory - Mohammad owns the tenant-safe session boundaries
REDIS_URL=redis://localhost:6379/0

# Object storage - Mohammad owns blob lifecycle and erasure paths
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=http://localhost:9000

# Secrets - Mohammad owns Vault integration and service tokens
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=change-me

# Widget auth - Ali Faddel owns the embed flow, token exchange, and origin checks
WIDGET_ISSUER=concierge-widget
WIDGET_TOKEN_TTL_SECONDS=300

# Model / AI - Hanan and Rayan coordinate these runtime settings
OPENAI_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-large
CHAT_MODEL=gpt-4.1-mini
CLASSIFIER_MODEL=classifier.onnx

# Observability - Rayan owns traces and eval visibility
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=concierge-api

